<% layout("/layouts/boilerplate") %>

<div class="row mt-4">
    <div class="col-11 offset-1 col-md-8 offset-md-2 col-lg-7 offset-lg-2">
        <h3 class="mb-4">My Bookings</h3>

        <% if (bookings.length === 0) { %>
            <div class="text-center py-5">
                <p class="text-muted fs-5 mb-3">You haven't made any bookings yet.</p>
                <a href="/listings" class="btn btn-dark px-4">Explore Listings</a>
            </div>
        <% } else { %>
            <% for (let booking of bookings) { %>
                <% if (!booking.listing) continue; %>
                <%
                    const now      = new Date();
                    const checkIn  = new Date(booking.checkIn);
                    const checkOut = new Date(booking.checkOut);
                    const upcoming = checkIn > now;
                    const active   = checkIn <= now && checkOut > now;

                    const fmtDate = (d) => new Date(d).toLocaleDateString("en-CA", {
                        weekday: "short", year: "numeric", month: "short", day: "numeric"
                    });

                    const badgeClass = upcoming ? "bg-success"
                                    : active   ? "bg-primary"
                                               : "bg-secondary";
                    const badgeText  = upcoming ? "Upcoming"
                                    : active   ? "Active"
                                               : "Completed";
                %>

                <div class="mb-4 border rounded-3 shadow-sm overflow-hidden" style="background:#fff;">

                    <%# Image — full width on top %>
                    <div style="height:200px; overflow:hidden;">
                        <img
                            src="<%= booking.listing.image ? booking.listing.image.url : '' %>"
                            alt="<%= booking.listing.title %>"
                            style="width:100%; height:100%; object-fit:cover; display:block;"
                        />
                    </div>

                    <%# Content below image %>
                    <div class="p-3 p-md-4">

                        <%# Title + badge %>
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <h5 class="fw-bold mb-0">
                                <a href="/listings/<%= booking.listing._id %>" class="text-dark text-decoration-none">
                                    <%= booking.listing.title %>
                                </a>
                            </h5>
                            <span class="badge <%= badgeClass %> ms-2 flex-shrink-0"><%= badgeText %></span>
                        </div>

                        <p class="text-muted small mb-3">
                            <%= booking.listing.location %>, <%= booking.listing.country %>
                        </p>

                        <%# Dates %>
                        <div class="d-flex gap-3 mb-3">
                            <div class="flex-fill border rounded-2 p-2 text-center">
                                <p class="text-muted small mb-0" style="font-size:11px; text-transform:uppercase; letter-spacing:.5px;">Check-in</p>
                                <p class="fw-semibold mb-0 small"><%= fmtDate(booking.checkIn) %></p>
                            </div>
                            <div class="d-flex align-items-center text-muted">→</div>
                            <div class="flex-fill border rounded-2 p-2 text-center">
                                <p class="text-muted small mb-0" style="font-size:11px; text-transform:uppercase; letter-spacing:.5px;">Check-out</p>
                                <p class="fw-semibold mb-0 small"><%= fmtDate(booking.checkOut) %></p>
                            </div>
                        </div>

                        <%# Nights + total + cancel %>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted small">
                                <%= booking.nights %> night<%= booking.nights !== 1 ? "s" : "" %> &middot;
                                <strong class="text-dark">CA$ <%= booking.totalPrice.toLocaleString("en-CA") %></strong>
                            </span>

                            <% if (upcoming) { %>
                                <form
                                    method="POST"
                                    action="/my-bookings/<%= booking._id %>?_method=DELETE"
                                    onsubmit="return confirm('Cancel this booking?')"
                                >
                                    <button class="btn btn-sm btn-outline-danger">Cancel</button>
                                </form>
                            <% } %>
                        </div>
                    </div>
                </div>

            <% } %>
        <% } %>
    </div>
</div>
