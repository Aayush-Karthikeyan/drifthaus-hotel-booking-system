<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
    <div class="col-10 offset-1 col-md-8 offset-md-2">
        <h3><%= listing.title %></h3>

        <div class="card show-card">
            <img
                src="<%= listing.image.url %>"
                class="card-img-top show-img"
                alt="listing_image"
            />
            <div class="card-body">
                <p class="card-text">
                    <%= listing.description %>
                    <br />
                    CA$ <%= listing.price.toLocaleString("en-CA") %> / night
                    <br />
                    <%= listing.location %>
                    <br />
                    <%= listing.country %>
                </p>
            </div>
        </div>

        <%# ── Booking Form ── %>
        <% if (currUser) { %>
            <% if (listing.owner && listing.owner._id && listing.owner._id.equals(currUser._id)) { %>
                <%# Owner sees edit / delete only %>
                <div class="btns">
                    <a
                        href="/listings/<%= listing._id %>/edit"
                        class="btn btn-dark edit-btn action-btn"
                    >Edit</a>

                    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                        <button class="btn btn-dark delete-btn action-btn">Delete</button>
                    </form>
                </div>
            <% } else { %>
                <%# Regular logged-in user sees the booking form %>
                <div class="booking-box mt-3 p-4 border rounded-3 shadow-sm" style="background:#f8f9fa;">
                    <h5 class="mb-1 fw-bold">
                        CA$ <%= listing.price.toLocaleString("en-CA") %>
                        <span class="fw-normal fs-6 text-muted">/ night</span>
                    </h5>

                    <form
                        action="/listings/<%= listing._id %>/book"
                        method="POST"
                        id="bookingForm"
                        class="mt-3"
                    >
                        <div class="row g-2">
                            <div class="col-6">
                                <label for="checkIn" class="form-label fw-semibold small">CHECK-IN</label>
                                <input
                                    type="date"
                                    id="checkIn"
                                    name="checkIn"
                                    class="form-control"
                                    required
                                />
                            </div>
                            <div class="col-6">
                                <label for="checkOut" class="form-label fw-semibold small">CHECK-OUT</label>
                                <input
                                    type="date"
                                    id="checkOut"
                                    name="checkOut"
                                    class="form-control"
                                    required
                                />
                            </div>
                        </div>

                        <div id="bookedWarning" class="mt-3 alert alert-danger py-2 small" style="display:none;">
                            ⚠️ These dates are already booked. Please choose different dates.
                        </div>

                        <div id="bookingSummary" class="mt-3 text-muted small" style="display:none;">
                            <hr class="my-2"/>
                            <div class="d-flex justify-content-between">
                                <span>
                                    CA$ <%= listing.price.toLocaleString("en-CA") %> &times;
                                    <span id="nightCount">0</span> nights
                                </span>
                                <span>CA$ <span id="totalPrice">0</span></span>
                            </div>
                            <hr class="my-2"/>
                            <div class="d-flex justify-content-between fw-bold text-dark">
                                <span>Total</span>
                                <span>CA$ <span id="totalPriceFinal">0</span></span>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-dark w-100 mt-3 py-2 fw-semibold">
                            Book Now
                        </button>
                        <p class="text-center text-muted small mt-2 mb-0">
                            A confirmation email will be sent to you.
                        </p>
                    </form>
                </div>
            <% } %>
        <% } else { %>
            <div class="mt-3 p-4 border rounded-3 text-center" style="background:#f8f9fa;">
                <p class="mb-2 fw-semibold">
                    CA$ <%= listing.price.toLocaleString("en-CA") %> / night
                </p>
                <a href="/login" class="btn btn-dark px-4">Login to Book</a>
            </div>
        <% } %>
    </div>

    <div class="col-10 offset-1 col-md-8 offset-md-2 mb-3">
        <hr />
        <h4>Where you'll be</h4>
        <div id="map"></div>

        <hr />

        <% if (currUser) { %>
            <h4>Leave a Review</h4>
            <form
                action="/listings/<%= listing._id %>/reviews"
                method="POST"
                novalidate
                class="needs-validation"
            >
                <div class="mb-3 mt-3">
                    <fieldset class="starability-basic">
                        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked aria-label="No rating." />
                        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                        <label for="first-rate1" title="Terrible">1 star</label>
                        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                        <label for="first-rate2" title="Not good">2 stars</label>
                        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                        <label for="first-rate3" title="Average">3 stars</label>
                        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                        <label for="first-rate4" title="Very good">4 stars</label>
                        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                        <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>
                </div>
                <div class="mb-3 mt-3">
                    <label for="comment" class="form-label">Comments</label>
                    <textarea
                        name="review[comment]"
                        id="comment"
                        cols="30"
                        rows="5"
                        class="form-control"
                        required
                    ></textarea>
                    <div class="invalid-feedback">Please add some comments for review</div>
                </div>
                <button class="btn btn-outline-dark">Submit</button>
            </form>
        <% } else { %>
            <p class="text-muted mb-4">
                <a href="/login">Login</a> to leave a review.
            </p>
        <% } %>

        <hr />
        <p><b>All Reviews</b></p>
        <% if (listing.reviews.length) { %>
            <div class="row">
                <% for (review of listing.reviews) { %>
                    <div class="card col-12 col-md-5 ms-0 me-md-3 mb-3 review-card">
                        <div class="card-body">
                            <h5 class="card-title">
                                <%= review.author && review.author.username ? review.author.username : "Jane Doe" %>
                            </h5>
                            <p class="card-text"><%= review.comment %></p>
                            <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
                            <% if (currUser && review.author && review.author._id && review.author._id.equals(currUser._id)) { %>
                                <form
                                    method="POST"
                                    action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                                >
                                    <button class="btn btn-sm btn-dark">Delete</button>
                                </form>
                            <% } %>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } else { %>
            <p class="text-muted">No reviews yet. Be the first to leave one.</p>
        <% } %>
    </div>
</div>
<script>
    window.listingData = <%- JSON.stringify(listing) %>;
    window.listingCoordinates = window.listingData.geometry
        ? window.listingData.geometry.coordinates
        : null;
</script>
<script src="/js/map.js"></script>
<script>
(function () {
    const pricePerNight = <%= listing.price %>;
    const bookedRanges  = <%- JSON.stringify(bookedRanges) %>;
    const checkInEl    = document.getElementById("checkIn");
    const checkOutEl   = document.getElementById("checkOut");
    const summary      = document.getElementById("bookingSummary");
    const nightCountEl = document.getElementById("nightCount");
    const totalEl      = document.getElementById("totalPrice");
    const totalFinalEl = document.getElementById("totalPriceFinal");

    if (!checkInEl || !checkOutEl) return;   // not shown (owner / logged-out)

    // Set minimum date to today
    const today = new Date().toISOString().split("T")[0];
    checkInEl.setAttribute("min", today);
    checkOutEl.setAttribute("min", today);

    // Check if a date range overlaps any booked range
    function overlapsBooked(ciStr, coStr) {
        if (!ciStr || !coStr) return false;
        const ci = new Date(ciStr);
        const co = new Date(coStr);
        return bookedRanges.some(r => {
            const rIn  = new Date(r.checkIn);
            const rOut = new Date(r.checkOut);
            return ci < rOut && co > rIn;
        });
    }

    function updateSummary() {
        const ci = new Date(checkInEl.value);
        const co = new Date(checkOutEl.value);
        if (!checkInEl.value || !checkOutEl.value || co <= ci) {
            summary.style.display = "none";
            return;
        }

        if (overlapsBooked(checkInEl.value, checkOutEl.value)) {
            summary.style.display = "none";
            checkInEl.setCustomValidity("These dates overlap an existing booking.");
            checkOutEl.setCustomValidity("These dates overlap an existing booking.");
            document.getElementById("bookedWarning").style.display = "block";
            return;
        }

        checkInEl.setCustomValidity("");
        checkOutEl.setCustomValidity("");
        document.getElementById("bookedWarning").style.display = "none";

        const nights = Math.round((co - ci) / (1000 * 60 * 60 * 24));
        const total  = nights * pricePerNight;
        nightCountEl.textContent = nights;
        const fmt = (n) => n.toLocaleString("en-CA");
        totalEl.textContent      = fmt(total);
        totalFinalEl.textContent = fmt(total);
        summary.style.display    = "block";
    }

    checkInEl.addEventListener("change", function () {
        if (checkOutEl.value && checkOutEl.value <= checkInEl.value) {
            checkOutEl.value = "";
            summary.style.display = "none";
        }
        checkOutEl.setAttribute("min", checkInEl.value);
        updateSummary();
    });

    checkOutEl.addEventListener("change", updateSummary);
})();
</script>
